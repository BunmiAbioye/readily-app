{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/passport/(.*)", "destination": "/index.html" },
    { "source": "/invite/(.*)", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/digest-cron",
      "schedule": "0 23 * * 5"
    }
  ]
}
